// All images used in this project are placed here for simple upgrade in future.
{
    // go compiler, protoc
    gocompiler: "mirror.gcr.io/golang:1.25",
    // go linter
    golangcilint: "mirror.gcr.io/golangci/golangci-lint:v2.4.0",
    // code generator
    oapicodegen: "ghcr.io/ogen-go/ogen:v1.14.0",
}
